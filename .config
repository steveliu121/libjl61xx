#
#OS configuration
#
CONFIG_OS_WIN=
CONFIG_OS_LINUX=y


#
#Register IO device configurations
#
CONFIG_IO_CPU=
CONFIG_IO_SMI=y
CONFIG_IO_I2C=
CONFIG_IO_SPI=
CONFIG_SMI_OVER_MDIO=y
CONFIG_SMI_OVER_GPIO=
CONFIG_SMI_OVER_SPI=
CONFIG_SMI_OVER_FTDI=
CONFIG_SMI_OVER_HID=


#
#Register IO debug configuration, dump register write
#
CONFIG_DUMP_REG_WRITE=


#
#Chip id configurations
#
CONFIG_CHIP_JL61XX=y
CONFIG_HW_VER_JL6105=
CONFIG_HW_VER_JL6108=
CONFIG_HW_VER_JL6110=y
CONFIG_HW_VER_JL61XX=


#
#Thread safe configuration
#
CONFIG_LIBSWITCH_MULTI_THREAD_SUPPORT=


#
#Libswitch debug configuration
#
CONFIG_LIBSWITCH_DEBUG_LEVEL=3
